---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const items = await getCollection('portfolio');

// Sort by date (descending)
const sortedItems = items.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Clean slug helper
const cleanSlug = (id: string) => id.replace('/index.md', '').replace('index.md', '').trim();
---

<Layout 
  title="Portfolio | Naren Vadapalli" 
  description="Professional media, gaming, VFX, and technical projects of Narendra Kumar Vadapalli"
>
  <div class="portfolio-index-page">
    <div class="page-header">
      <div class="container">
        <h1>My Portfolio</h1>
        <p class="subtitle">A showcase of media, game development, graphics plugin tools, and graduation research projects.</p>
      </div>
    </div>

    <div class="container portfolio-list-container">
      <div class="portfolio-grid">
        {sortedItems.map(item => {
          const slug = cleanSlug(item.id);
          
          return (
            <div class="card portfolio-list-card">
              {item.data.image && (
                <div class="image-wrapper">
                  <Image 
                    src={item.data.image} 
                    alt={item.data.title}
                    class="portfolio-img"
                  />
                </div>
              )}
              <div class="portfolio-card-content">
                <h2>{item.data.title}</h2>
                {item.data.description && <p>{item.data.description}</p>}
                <a href={`/portfolio/${slug}`} class="btn btn-primary">
                  View Project Details
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</Layout>

<style>
  .portfolio-index-page {
    padding-bottom: 5rem;
  }

  .page-header {
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .portfolio-list-container {
    margin-top: 4rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  .portfolio-list-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: rgba(17, 21, 32, 0.4);
    border: 1px solid var(--glass-border);
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }

  .portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }

  .portfolio-list-card:hover .portfolio-img {
    transform: scale(1.05);
  }

  .portfolio-card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .portfolio-card-content h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .portfolio-card-content p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-size: 1rem;
    flex-grow: 1;
    line-height: 1.5;
  }

  .portfolio-card-content .btn {
    align-self: flex-start;
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
