    url: "https://www.animallogic.com",
    date: "2016 (Jan) - 2017 (Jul)",
    logo: "/images/work_edu/animal_logic_logo.jpg",
    details: "Developed render statistics reporting pipelines to track system optimization. Built lighting tools to optimize artist workflow. Created projection automation pipelines mapping live-action plates to LIDAR geometry for 'Peter Rabbit'."
  },
  {
    role: "Department Technical Director",
    company: "DreamWorks Animations",
    location: "Bengaluru, India",
    url: "https://www.dreamworks.com",
    date: "2012 (Feb) - 2015 (Dec)",
    logo: "/images/work_edu/dreamworks_logo.jpg",
    details: "Provided FX pipeline tool development and Houdini support for features: 'Penguins of Madagascar', 'Kung Fu Panda 3', and 'The Boss Baby'. Maintained and upgraded animation pipelines for 'Mr. Peabody & Sherman' and episodic content for Cartoon Network ('Dragons - Riders of Berk')."
  },
  {
    role: "CG Software Engineer - Intern",
    company: "EA Sports Tiburon",
    location: "Orlando, FL, USA",
    url: "https://www.easports.com",
    date: "2011 (May) - 2011 (Aug)",
