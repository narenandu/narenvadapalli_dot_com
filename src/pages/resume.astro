    ]
  },
  {
    name: "Web Frameworks & Protocols",
    icon: "/images/skills/web_frameworks.png",
    items: [
      { name: "Flask", logo: "/images/skills/flask.png" },
      { name: "React", logo: "/images/skills/react.png" },
      { name: "Vue", logo: "/images/skills/vue.png" },
      { name: "gRPC", logo: "/images/skills/grpc.png" },
      { name: "jQuery", logo: "/images/skills/jquery.svg" }
    ]
  },
  {
    name: "Data Science & Databases",
    icon: "/images/skills/db.png",
    items: [
      { name: "Pandas", logo: "/images/skills/pandas.png" },
      { name: "NumPy", logo: "/images/skills/numpy.png" },
      { name: "Matplotlib", logo: "/images/skills/matplotlib.png" },
      { name: "MySQL", logo: "/images/skills/mysql.png" }
    ]
  },
  {
    name: "DevOps & Version Control",
    icon: "/images/skills/devops.png",
    items: [
      { name: "Docker", logo: "/images/skills/docker.png" },
      { name: "OpenShift", logo: "/images/skills/openshift.png" },
      { name: "Jenkins", logo: "/images/skills/jenkins.svg" },
      { name: "Git", logo: "/images/skills/git.svg" },
