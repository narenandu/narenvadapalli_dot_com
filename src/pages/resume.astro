---

<Layout
  title="Resume | Naren Vadapalli"
  description="Professional Resume of Narendra Kumar Vadapalli - Lead Site Reliability Engineer, Pipeline TD, and Founder of Skynet Technology Ltd."
>
  <div class="resume-page">
    <div class="page-header">
      <div class="container">
        <h1>My Resume</h1>
        <p class="subtitle">A track record of engineering software and reliability pipelines for global media and technology companies.</p>
      </div>
    </div>

    <div class="container content-container">
      <!-- WORK EXPERIENCE -->
      <section class="resume-section">
        <h2 class="section-title-bar">Work Experience</h2>
        <div class="timeline">
          {experience.map(item => (
            <div class="timeline-item">
              <div class="timeline-badge-wrapper">
                <div class="timeline-badge">
                  <img src={item.logo} alt={item.company} onerror="this.src='/favicon.svg'" />
                </div>
              </div>
              <div class="card timeline-card">
                <div class="timeline-header">
                  <div>
                    <h3>{item.role}</h3>
                    <h4>
                      {item.url ? (
                        <a href={item.url} target="_blank" rel="noopener noreferrer" class="company-link">
                          {item.company}
                        </a>
                      ) : (
                        item.company
                      )}
                      {item.location && (
                        <>
                          <span class="location-separator"> &bull; </span>
                          <span class="location-text">{item.location}</span>
                        </>
                      )}
                    </h4>
                  </div>
                  <span class="timeline-date">{item.date}</span>
                </div>
                <p class="timeline-details">{item.details}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- EDUCATION -->
      <section class="resume-section">
        <h2 class="section-title-bar">Education</h2>
        <div class="timeline">
          {education.map(item => (
            <div class="timeline-item">
              <div class="timeline-badge-wrapper">
                <div class="timeline-badge">
                  <img src={item.logo} alt={item.school} onerror="this.src='/favicon.svg'" />
                </div>
              </div>
              <div class="card timeline-card">
                <div class="timeline-header">
                  <div>
                    <h3>{item.degree}</h3>
                    <h4>{item.school}</h4>
                  </div>
                  <span class="timeline-date">{item.date}</span>
                </div>
                <p class="timeline-details">{item.details}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- SKILLS GRID -->
      <section class="resume-section">
        <h2 class="section-title-bar">Skills</h2>
        <div class="skills-grid">
          {skillCategories.map(category => (
            <div class="card skill-category-card">
              <div class="skill-category-header">
                <img src={category.icon} alt={category.name} class="category-icon" onerror="this.style.display='none'" />
                <h3>{category.name}</h3>
              </div>
              <div class="skill-items">
                {category.items.map(skill => (
                  <div class="skill-tag">
                    <img src={skill.logo} alt={skill.name} class="skill-icon" onerror="this.style.display='none'" />
                    <span>{skill.name}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .resume-page {
    padding-bottom: 5rem;
  }

  .page-header {
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .content-container {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .resume-section {
    position: relative;
  }

  .section-title-bar {
    font-size: 2rem;
    margin-bottom: 3rem;
    text-align: center;
    border-bottom: none;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Custom CSS Timeline */
  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 40px;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent-color) 0%, var(--teal-accent) 100%);
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
    display: flex;
    gap: 2rem;
  }

  .timeline-badge-wrapper {
    width: 80px;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-shrink: 0;
  }

  .timeline-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    border: 2px solid var(--accent-color);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.4);
  }

  .timeline-badge img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .timeline-card {
    flex-grow: 1;
    background: rgba(17, 21, 32, 0.5);
    border: 1px solid var(--glass-border);
    padding: 2rem;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }

  .timeline-header h3 {
    margin: 0 0 0.25rem;
    font-size: 1.35rem;
  }

  .timeline-header h4 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .company-link {
    color: inherit;
    text-decoration: none;
    transition: var(--transition);
  }

  .company-link:hover {
    color: var(--teal-accent);
    text-decoration: underline;
  }

  .location-separator {
    color: var(--border-color);
    margin: 0 0.25rem;
    font-weight: 300;
  }

  .location-text {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-secondary);
    opacity: 0.85;
  }

  .timeline-date {
    font-family: var(--font-display);
    color: var(--teal-accent);
    font-weight: 600;
    font-size: 0.95rem;
    background: rgba(20, 184, 166, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(20, 184, 166, 0.2);
  }

  .timeline-details {
    margin: 0;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Skills Section */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .skill-category-card {
    background: rgba(17, 21, 32, 0.4);
    border: 1px solid var(--glass-border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-category-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  .category-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border-radius: 4px;
  }

  .skill-category-header h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 0.5rem 0.85rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: var(--transition);
  }

  .skill-tag:hover {
    border-color: var(--accent-color);
    background: rgba(139, 92, 246, 0.08);
    transform: translateY(-2px);
  }

  .skill-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .timeline::before {
      left: 20px;
    }

    .timeline-item {
      gap: 1rem;
    }

    .timeline-badge-wrapper {
      width: 40px;
    }

    .timeline-badge {
      width: 36px;
      height: 36px;
    }

    .timeline-card {
      padding: 1.25rem;
    }

    .timeline-header {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
