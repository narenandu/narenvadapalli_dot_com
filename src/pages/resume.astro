  },
  {
    role: "Chief Pipeline Technical Director",
    company: "On Animation Studios",
    location: "Montreal, QC, Canada",
    url: "https://www.onanimationstudios.com",
    date: "2017 (Oct) - 2018 (Jun)",
    logo: "/images/work_edu/on_animation_logo.jpg",
    details: "Supervised the Pipeline and Render/Data Wrangling teams. Designed core pipeline modules used across all departments. Built batch rendering configurations on Guerilla Renderer and designed data analytics tools for render-time prediction."
  },
