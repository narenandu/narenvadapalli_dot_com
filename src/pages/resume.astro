  },
  {
    role: "Lead Software Engineer",
    company: "Samsung India Software Operations",
    location: "Bengaluru, India",
    url: "https://www.samsung.com",
    date: "2007 (Sep) - 2010 (Jul)",
    logo: "/images/work_edu/samsung_logo.jpg",
    details: "Embedded software development for CDMA mobile applications. Developed and maintained the MP3 Player application frontend, and performed messaging/browser validation."
  },
  {
    role: "Software Engineer",
    company: "Motorola India Pvt Ltd",
    location: "Bengaluru, India",
    url: "https://www.motorola.com",
    date: "2006 (May) - 2007 (Sep)",
    logo: "/images/work_edu/motorola_logo.jpg",
    details: "Responsible for BREW PEK performance optimization, bug fixing, and carrier-specific API validation for CDMA mobile phones."
  }
];

const education = [
  {
    degree: "MSE in Computer Graphics and Game Technology",
    school: "University of Pennsylvania, Philadelphia, PA, USA",
    date: "2010 (Sep) - 2011 (Dec)",
