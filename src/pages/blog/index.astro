---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');

// Sort posts by date (descending)
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Clean slug helper
const cleanSlug = (id: string) => id.replace('/index.md', '').replace('index.md', '').trim();
---

<Layout 
  title="Blog | Naren Vadapalli" 
  description="Personal blog of Naren Vadapalli covering DevOps, Software Engineering, Python, VFX, and Automation"
>
  <div class="blog-index-page">
    <div class="page-header">
      <div class="container">
        <h1>My Blog</h1>
        <p class="subtitle">Reflections on software engineering, pipeline automation, graphics, and system reliability.</p>
      </div>
    </div>

    <div class="container blog-list-container">
      <div class="filter-status" id="filterStatus" style="display: none;">
        <span class="filter-text">Showing articles tagged with: <strong id="activeTagName"></strong></span>
        <button id="clearFilterBtn" class="clear-filter-btn">Clear Filter</button>
      </div>

      <div class="blog-grid">
        {sortedPosts.map(post => {
          const dateString = post.data.date 
            ? post.data.date.toLocaleDateString('en-US', {
                timeZone: 'UTC',
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })
            : '';
            
          const slug = cleanSlug(post.id);
          const tagsList = post.data.tags ? post.data.tags.join(',') : 'tech';
          
          return (
            <article class="card blog-list-card" data-tags={tagsList}>
              {post.data.image && (
                <div class="card-thumbnail">
                  <a href={`/blog/${slug}`}>
                    <Image 
                      src={post.data.image} 
                      alt={post.data.title}
                      class="thumbnail-img"
                    />
                  </a>
                </div>
              )}
              <div class="card-content">
                <div class="card-meta">
                  <span class="card-date">{dateString}</span>
                  <div class="card-badges">
                    {post.data.tags && post.data.tags.map(tag => (
                      <button class="card-badge tag-button" data-tag={tag}>{tag}</button>
                    ))}
                    {(!post.data.tags || post.data.tags.length === 0) && (
                      <button class="card-badge tag-button" data-tag="tech">Tech</button>
                    )}
                  </div>
                </div>
                <h2>
                  <a href={`/blog/${slug}`}>{post.data.title}</a>
                </h2>
                {post.data.description && <p class="card-description">{post.data.description}</p>}
                <div class="card-footer">
                  <a href={`/blog/${slug}`} class="read-more">
                    Read Article &rarr;
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-index-page {
    padding-bottom: 5rem;
  }

  .page-header {
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .blog-list-container {
    margin-top: 3rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .blog-list-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    background: rgba(17, 21, 32, 0.4);
    border: 1px solid var(--glass-border);
    align-items: stretch;
    min-height: 140px;
  }

  .card-thumbnail {
    width: 20%;
    min-width: 100px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius-sm, 6px);
    border: 1px solid var(--glass-border);
    display: flex;
  }

  .card-thumbnail a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }

  .blog-list-card:hover .thumbnail-img {
    transform: scale(1.05);
  }

  .card-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
  }

  .card-date {
    color: var(--teal-accent);
    font-weight: 500;
  }

  .card-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-badge {
    background: rgba(139, 92, 246, 0.15);
    color: var(--accent-color);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    border: 1px solid rgba(139, 92, 246, 0.3);
    font-weight: 600;
  }

  .blog-list-card h2 {
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
  }

  .blog-list-card h2 a {
    color: var(--text-primary);
  }

  .blog-list-card h2 a:hover {
    color: var(--accent-color);
  }

  .card-description {
    color: var(--text-secondary);
    margin-bottom: 0.85rem;
    flex-grow: 1;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .card-footer {
    display: flex;
    align-items: center;
  }

  .read-more {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--accent-color);
    transition: var(--transition);
  }

  .read-more:hover {
    color: var(--text-primary);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-list-card {
      padding: 1rem;
      gap: 1.2rem;
    }
    .card-thumbnail {
      width: 20%;
      min-width: 75px;
    }
    .blog-list-card h2 {
      font-size: 1.3rem;
      margin-bottom: 0.5rem;
    }
    .card-description {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }
  }

  /* Filter Status Header */
  .filter-status {
    background: rgba(0, 242, 254, 0.06);
    border: 1px solid rgba(0, 242, 254, 0.15);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin: 0 auto 3rem; /* Centered horizontally with 3rem bottom margin to push cards down */
    max-width: 800px;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  .clear-filter-btn {
    background: none;
    border: 1px solid var(--accent-color);
    color: var(--accent-color);
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: var(--transition);
  }

  .clear-filter-btn:hover {
    background: var(--accent-color);
    color: var(--bg-primary);
  }

  /* Hidden Card Styles */
  .blog-list-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .blog-list-card.hidden-card {
    display: none !important; /* Force complete removal from grid to resolve min-height and overflow layout issues */
  }

  /* Active tag button styling */
  .tag-button.active-tag {
    background: var(--accent-color);
    color: var(--bg-primary);
    border-color: var(--accent-color);
  }
</style>

<script>
  // Client-side tag filtering
  const filterStatus = document.getElementById('filterStatus');
  const activeTagName = document.getElementById('activeTagName');
  const clearFilterBtn = document.getElementById('clearFilterBtn');
  const cards = document.querySelectorAll('.blog-list-card');
  const tagButtons = document.querySelectorAll('.tag-button');

  let activeTag = null;

  function setFilter(tag) {
    activeTag = tag ? tag.toLowerCase().trim() : null;

    if (activeTag) {
      // Show active filter bar
      if (activeTagName) activeTagName.textContent = `#${activeTag}`;
      if (filterStatus) filterStatus.style.display = 'flex';

      // Update URL query parameter without page reload
      const url = new URL(window.location.href);
      url.searchParams.set('tag', activeTag);
      window.history.replaceState({}, '', url.toString());

      // Filter cards
      cards.forEach(card => {
        const tagsAttr = card.getAttribute('data-tags');
        const tags = tagsAttr ? tagsAttr.split(',').map(t => t.trim().toLowerCase()) : [];
        if (tags.includes(activeTag)) {
          card.classList.remove('hidden-card');
        } else {
          card.classList.add('hidden-card');
        }
      });
    } else {
      // Clear filter bar
      if (filterStatus) filterStatus.style.display = 'none';

      // Remove URL query parameter
      const url = new URL(window.location.href);
      url.searchParams.delete('tag');
      window.history.replaceState({}, '', url.toString());

      // Show all cards
      cards.forEach(card => {
        card.classList.remove('hidden-card');
      });
    }

    // Highlight currently active tag buttons
    tagButtons.forEach(btn => {
      const btnTag = btn.getAttribute('data-tag');
      if (activeTag && btnTag && btnTag.toLowerCase().trim() === activeTag) {
        btn.classList.add('active-tag');
      } else {
        btn.classList.remove('active-tag');
      }
    });
  }

  // Handle clicking tag buttons
  tagButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const tag = btn.getAttribute('data-tag');
      setFilter(tag === activeTag ? null : tag);
    });
  });

  // Handle clear filter button
  if (clearFilterBtn) {
    clearFilterBtn.addEventListener('click', () => {
      setFilter(null);
    });
  }

  // Check URL parameters on load
  const params = new URLSearchParams(window.location.search);
  const tagParam = params.get('tag');
  if (tagParam) {
    setFilter(tagParam);
  }
</script>
