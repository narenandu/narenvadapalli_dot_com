---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');

// Sort posts by date (descending)
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Clean slug helper
const cleanSlug = (id: string) => id.replace('/index.md', '').replace('index.md', '').trim();
---

<Layout 
  title="Blog | Naren Vadapalli" 
  description="Personal blog of Naren Vadapalli covering DevOps, Software Engineering, Python, VFX, and Automation"
>
  <div class="blog-index-page">
    <div class="page-header">
      <div class="container">
        <h1>My Blog</h1>
        <p class="subtitle">Reflections on software engineering, pipeline automation, graphics, and system reliability.</p>
      </div>
    </div>

    <div class="container blog-list-container">
      <div class="blog-grid">
        {sortedPosts.map(post => {
          const dateString = post.data.date 
            ? post.data.date.toLocaleDateString('en-US', {
                timeZone: 'UTC',
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })
            : '';
            
          const slug = cleanSlug(post.id);
          
          return (
            <article class="card blog-list-card">
              {post.data.image && (
                <div class="card-thumbnail">
                  <a href={`/blog/${slug}`}>
                    <Image 
                      src={post.data.image} 
                      alt={post.data.title}
                      class="thumbnail-img"
                    />
                  </a>
                </div>
              )}
              <div class="card-content">
                <div class="card-meta">
                  <span class="card-date">{dateString}</span>
                  <span class="card-badge">Tech</span>
                </div>
                <h2>
                  <a href={`/blog/${slug}`}>{post.data.title}</a>
                </h2>
                {post.data.description && <p class="card-description">{post.data.description}</p>}
                <div class="card-footer">
                  <a href={`/blog/${slug}`} class="read-more">
                    Read Article &rarr;
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-index-page {
    padding-bottom: 5rem;
  }

  .page-header {
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .blog-list-container {
    margin-top: 3rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .blog-list-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    background: rgba(17, 21, 32, 0.4);
    border: 1px solid var(--glass-border);
    align-items: stretch;
    min-height: 140px;
  }

  .card-thumbnail {
    width: 20%;
    min-width: 100px;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: var(--radius-sm, 6px);
    border: 1px solid var(--glass-border);
    display: flex;
  }

  .card-thumbnail a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition);
  }

  .blog-list-card:hover .thumbnail-img {
    transform: scale(1.05);
  }

  .card-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
  }

  .card-date {
    color: var(--teal-accent);
    font-weight: 500;
  }

  .card-badge {
    background: rgba(139, 92, 246, 0.15);
    color: var(--accent-color);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    border: 1px solid rgba(139, 92, 246, 0.3);
    font-weight: 600;
  }

  .blog-list-card h2 {
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
  }

  .blog-list-card h2 a {
    color: var(--text-primary);
  }

  .blog-list-card h2 a:hover {
    color: var(--accent-color);
  }

  .card-description {
    color: var(--text-secondary);
    margin-bottom: 0.85rem;
    flex-grow: 1;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .card-footer {
    display: flex;
    align-items: center;
  }

  .read-more {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--accent-color);
    transition: var(--transition);
  }

  .read-more:hover {
    color: var(--text-primary);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-list-card {
      padding: 1rem;
      gap: 1.2rem;
    }
    .card-thumbnail {
      width: 20%;
      min-width: 75px;
    }
    .blog-list-card h2 {
      font-size: 1.3rem;
      margin-bottom: 0.5rem;
    }
    .card-description {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }
  }
</style>
